# ─────────────────────────────────────────
# DEPENDENCIES
# ─────────────────────────────────────────
node_modules/
.pnpm-store/

# ─────────────────────────────────────────
# BUILD OUTPUTS
# ─────────────────────────────────────────
dist/
build/
out/
.next/
.turbo/
*.tsbuildinfo

# ─────────────────────────────────────────
# EXPO / REACT NATIVE
# ─────────────────────────────────────────
.expo/
.expo-shared/

# Native build folders — generated by `expo prebuild` or `eas build`
# Never commit these; regenerate with: npx expo prebuild
apps/mobile/android/
apps/mobile/ios/

# EAS build artifacts
*.apk
*.aab
*.ipa

# Metro bundler cache
.metro-cache/

# ─────────────────────────────────────────
# ENVIRONMENT & SECRETS — NEVER COMMIT
# ─────────────────────────────────────────
.env
.env.local
.env.development
.env.staging
.env.production
.env.*.local

# Keep .env.example files — they document required variables
!.env.example

# ─────────────────────────────────────────
# MOBILE SECRETS & SIGNING
# ─────────────────────────────────────────
# Android signing
*.keystore
*.jks
google-services.json          # Firebase / FCM config (contains API key)
google-play-key.json          # Google Play service account key

# iOS signing
GoogleService-Info.plist      # Firebase iOS config (contains API key)
*.p8                          # Apple push notification key
*.p12                         # iOS distribution certificate
*.cer                         # Apple certificate
*.mobileprovision             # Provisioning profile
AuthKey_*.p8                  # App Store Connect API key

# EAS secrets (auto-generated by eas credentials)
credentials.json

# ─────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────
# Prisma generated client is built on install — don't commit it
packages/db/node_modules/
# But DO commit the schema and migrations
!packages/db/prisma/schema.prisma
!packages/db/prisma/migrations/

# ─────────────────────────────────────────
# LOGS
# ─────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─────────────────────────────────────────
# OS / EDITOR
# ─────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
Desktop.ini

.idea/
.vscode/settings.json         # personal settings — but keep extensions.json
!.vscode/extensions.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─────────────────────────────────────────
# TESTING & COVERAGE
# ─────────────────────────────────────────
coverage/
.nyc_output/
*.lcov

# ─────────────────────────────────────────
# MISC
# ─────────────────────────────────────────
*.pem                         # any private key / cert
.vercel
.railway
