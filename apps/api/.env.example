# ─────────────────────────────────────────
# ROAM API — Environment Variables
# Copy to .env and fill in values
# ─────────────────────────────────────────

# App
NODE_ENV=development
PORT=4000
API_URL=http://localhost:4000
FRONTEND_URL=http://localhost:8081

# Database (Railway PostgreSQL)
DATABASE_URL=postgresql://dating:dating_dev_password@localhost:5432/dating_db

# Redis (Upstash)
REDIS_URL=redis://default:password@host:port

# JWT (generate with: openssl genrsa -out private.pem 2048)
JWT_ACCESS_SECRET=your-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Africa's Talking (SMS OTP)
AT_API_KEY=your-africastalking-api-key
AT_USERNAME=sandbox          # or your production username
AT_SENDER_ID=ROAM            # Short code / sender name

# PesaPal
PESAPAL_CONSUMER_KEY=your-pesapal-consumer-key
PESAPAL_CONSUMER_SECRET=your-pesapal-consumer-secret
PESAPAL_BASE_URL=https://cybqa.pesapal.com/pesapalv3  # sandbox
# Production: https://pay.pesapal.com/v3
PESAPAL_IPN_URL=https://api.dating.app/webhooks/pesapal
PESAPAL_CALLBACK_URL=https://app.dating.app/payment/callback

# Cloudflare R2 (photos/media storage)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=dating-media
R2_PUBLIC_URL=https://media.dating.app

# Cloudflare Stream (videos)
CF_STREAM_TOKEN=your-cloudflare-stream-token

# OpenAI (AI matching + content moderation)
OPENAI_API_KEY=sk-your-openai-api-key

# LiveKit (video/voice calls)
LIVEKIT_URL=wss://your-livekit-server.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# Expo Push Notifications
EXPO_ACCESS_TOKEN=your-expo-access-token
